---
import "../../src/styles/global.css";
import CollectionQuery from "../../../src/components/CollectionQuery.astro";
import ServerCollectionQueryResults from "../components/ServerCollectionQueryResults.astro";
import GuideLayout from "../layouts/GuideLayout.astro";
import { matchesCollectionFilters, paginateCollection, parseCollectionQuery } from "../../../src/collection-query";

const nav = [
  { href: "/", label: "Overview" },
  { href: "/paging", label: "Paging" },
  { href: "/summaries", label: "Summaries" },
  { href: "/modals", label: "Modals" },
  { href: "/controls", label: "Controls" },
  { href: "/media", label: "Media" },
];

const cards = [
  { title: "Alpha release notes", tags: ["ops", "platform"] },
  { title: "Beta product diary", tags: ["product"] },
  { title: "Gamma render trial", tags: ["platform", "ux"] },
  { title: "Delta launch prep", tags: ["ops"] },
  { title: "Epsilon editorial flow", tags: ["content", "ux"] },
];
const clientSizeOptions = [1, 2, 3, 4, 5, 10];
const clientSizeRaw = Number.parseInt(Astro.url.searchParams.get("clientSize") ?? "2", 10);
const clientSize = Number.isFinite(clientSizeRaw) ? Math.max(1, clientSizeRaw) : 2;
const serverSizeOptions = [1, 2, 3, 4, 5, 10];
const serverQuery = parseCollectionQuery(Astro.url.searchParams, { defaultSize: 1 });
const serverFilteredCards =
  Object.keys(serverQuery.filters).length === 0
    ? cards
    : cards.filter((card) => matchesCollectionFilters({ tag: card.tags }, serverQuery.filters));
const serverPageData = paginateCollection(serverFilteredCards, serverQuery);
const serverCurrentPage = Math.min(
  serverPageData.totalPages,
  Math.max(1, Math.floor(serverQuery.offset / serverQuery.size) + 1),
);
const serverActiveQuery = {
  ...serverQuery,
  page: serverCurrentPage,
  offset: (serverCurrentPage - 1) * serverQuery.size,
};
const serverFilterTags = Array.from(new Set(cards.flatMap((card) => card.tags))).sort((a, b) =>
  a.localeCompare(b),
);
const serverFiltersValue =
  Object.keys(serverActiveQuery.filters).length > 0 ? JSON.stringify(serverActiveQuery.filters) : "";
const shouldDeferResults = Astro.url.search.length === 0;
---

<GuideLayout title="Astroflare Styleguide" nav={nav}>
  <section class="sg-card sg-grid">
    <h2>Client filtering and paging</h2>
    <p class="sg-muted">Entire dataset stays in the browser, including page-size controls.</p>
    <form method="get" class="sg-size-form">
      <label for="sg-client-size-select">Page size</label>
      <select id="sg-client-size-select" name="clientSize" onchange="this.form.submit()">
        {clientSizeOptions.map((size) => (
          <option value={String(size)} selected={clientSize === size}>{size}</option>
        ))}
      </select>
      {Astro.url.searchParams.get("size") && <input type="hidden" name="size" value={Astro.url.searchParams.get("size") ?? ""} />}
      {Astro.url.searchParams.get("page") && <input type="hidden" name="page" value={Astro.url.searchParams.get("page") ?? ""} />}
      {Astro.url.searchParams.get("offset") && <input type="hidden" name="offset" value={Astro.url.searchParams.get("offset") ?? ""} />}
      {Astro.url.searchParams.get("filters") && <input type="hidden" name="filters" value={Astro.url.searchParams.get("filters") ?? ""} />}
    </form>
    <CollectionQuery perPage={clientSize}>
      <div class="sg-grid">
        {cards.map((card) => (
          <article data-card data-tags={card.tags.join("|")} class="sg-card">
            <h3>{card.title}</h3>
            <p>{card.tags.join(" / ")}</p>
          </article>
        ))}
      </div>
    </CollectionQuery>
  </section>

  <section class="sg-card sg-grid">
    <h2>Server query paging</h2>
    <p class="sg-muted">Controls render immediately; only result content is deferred to reduce flicker.</p>
    <form method="get" class="sg-size-form">
      <label for="sg-server-size-select">Page size</label>
      <select id="sg-server-size-select" name="size" onchange="this.form.submit()">
        {serverSizeOptions.map((size) => (
          <option value={String(size)} selected={serverActiveQuery.size === size}>{size}</option>
        ))}
      </select>
      <input type="hidden" name="page" value="1" />
      <input type="hidden" name="offset" value="0" />
      {Astro.url.searchParams.get("clientSize") && (
        <input type="hidden" name="clientSize" value={Astro.url.searchParams.get("clientSize") ?? ""} />
      )}
      {serverFiltersValue && <input type="hidden" name="filters" value={serverFiltersValue} />}
    </form>
    <CollectionQuery
      useServer
      pathname={Astro.url.pathname}
      query={serverActiveQuery}
      totalPages={serverPageData.totalPages}
      currentPage={serverCurrentPage}
      filters={serverFilterTags.map((tag) => ({ key: "tag", value: tag }))}
    />
    {shouldDeferResults ? (
      <ServerCollectionQueryResults search={Astro.url.search} server:defer>
        <div slot="fallback" class="sg-grid sg-server-results sg-server-fallback">
          <div class="sg-controls-skeleton" aria-hidden="true"></div>
          <div class="sg-grid sg-server-results">
            <article class="sg-card sg-skeleton-card" aria-hidden="true"></article>
          </div>
        </div>
      </ServerCollectionQueryResults>
    ) : (
      <ServerCollectionQueryResults search={Astro.url.search} />
    )}
  </section>
</GuideLayout>
