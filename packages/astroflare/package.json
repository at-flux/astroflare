{
  "name": "@at-flux/astroflare",
  "version": "1.0.1",
  "type": "module",
  "description": "Reusable headless components, styles, and utilities for Astro + Tailwind v4 + Cloudflare projects",
  "author": "Taylor Siviter <taylor@siviter.xyz>",
  "license": "MIT",
  "keywords": [
    "astro",
    "tailwind",
    "cloudflare",
    "components",
    "web-components"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./forms": {
      "import": {
        "types": "./dist/forms/index.d.ts",
        "default": "./dist/forms/index.js"
      },
      "require": {
        "types": "./dist/forms/index.d.cts",
        "default": "./dist/forms/index.cjs"
      }
    },
    "./dom": {
      "import": {
        "types": "./dist/dom.d.ts",
        "default": "./dist/dom.js"
      },
      "require": {
        "types": "./dist/dom.d.cts",
        "default": "./dist/dom.cjs"
      }
    },
    "./components/*": "./src/components/*",
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/components",
    "src/styles",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "resend": "^4.0.0"
  },
  "peerDependencies": {
    "astro": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/astroflare.git"
  },
  "bugs": {
    "url": "https://github.com/at-flux/astroflare/issues"
  },
  "homepage": "https://github.com/at-flux/astroflare#readme",
  "publishConfig": {
    "access": "public"
  }
}
