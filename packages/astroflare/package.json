{
  "name": "@at-flux/astroflare",
  "version": "1.0.3",
  "type": "module",
  "description": "Reusable headless components, styles, and utilities for Astro + Tailwind v4 + Cloudflare projects",
  "author": "atflux <dev@atflux.uk>",
  "license": "MIT",
  "keywords": [
    "astro",
    "tailwind",
    "cloudflare",
    "components",
    "web-components"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./forms": {
      "import": {
        "types": "./dist/forms/index.d.ts",
        "default": "./dist/forms/index.js"
      },
      "require": {
        "types": "./dist/forms/index.d.cts",
        "default": "./dist/forms/index.cjs"
      }
    },
    "./components/*": "./src/components/*",
    "./styles/*": "./src/styles/*"
  },
  "bin": {
    "astroflare-link-local": "./scripts/link-local.mjs"
  },
  "files": [
    "dist",
    "src/components",
    "src/runtime",
    "src/styles",
    "scripts/link-local.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "styleguide:dev": "astro dev --root styleguide",
    "styleguide:build": "astro build --root styleguide",
    "styleguide:preview": "astro preview --root styleguide",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@astrojs/node": "^9.5.5",
    "jsdom": "^25.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "resend": "^4.0.0"
  },
  "peerDependencies": {
    "astro": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/astroflare.git",
    "directory": "packages/astroflare"
  },
  "bugs": {
    "url": "https://github.com/at-flux/astroflare/issues"
  },
  "homepage": "https://github.com/at-flux/astroflare/tree/main/packages/astroflare",
  "publishConfig": {
    "access": "public"
  }
}
