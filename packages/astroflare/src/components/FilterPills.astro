---
import { getTagPalette } from "../tag-colors";

interface Props {
  /** Tag/filter values rendered as clickable pills. */
  items: Array<
    | string
    | {
        value: string;
        label?: string;
        href?: string;
        active?: boolean;
        disabled?: boolean;
        colorKey?: string;
      }
  >;
  /** Include an "all" filter option first. */
  includeAll?: boolean;
  /** Label shown for the catch-all filter. */
  allLabel?: string;
  /** Optional URL for the catch-all filter pill (renders as link when set). */
  allHref?: string;
  /** Initial active filter value. */
  active?: string;
  /** Optional casing transform for labels. */
  itemCase?: "none" | "upper";
  /** Explicit color map by lowercase tag key. */
  colorOverrides?: Record<string, string>;
  /** Classes applied to the pill row wrapper. */
  class?: string;
}

const {
  items,
  includeAll = true,
  allLabel = "All",
  allHref,
  active = "all",
  itemCase = "upper",
  colorOverrides,
  class: className = "",
} = Astro.props;

const formatLabel = (value: string): string =>
  itemCase === "upper" ? value.toUpperCase() : value;
const normalize = (value: string): string => value.trim().toLowerCase();
const formPartsFromHref = (href: string): { action: string; fields: Array<{ name: string; value: string }> } => {
  const url = new URL(href, "https://astroflare.local");
  return {
    action: url.pathname,
    fields: Array.from(url.searchParams.entries()).map(([name, value]) => ({ name, value })),
  };
};

const normalizedItems = items.map((item) =>
  typeof item === "string"
    ? { value: item, label: item }
    : {
        value: item.value,
        label: item.label ?? item.value,
        href: item.href,
        active: item.active,
        disabled: item.disabled,
        colorKey: item.colorKey,
      },
);
---

<div class:list={["af-filter-pills flex flex-wrap items-center gap-2", className]}>
  {includeAll && (
    allHref ? (
      (() => {
        const form = formPartsFromHref(allHref);
        return (
          <form method="get" action={form.action} data-astro-reload class="af-filter-pill-form">
            {form.fields.map((field) => (
              <input type="hidden" name={field.name} value={field.value} />
            ))}
            <button
              type="submit"
              class:list={["af-filter-pill", "af-filter-pill-all", active === "all" && "is-active"]}
            >
              {formatLabel(allLabel)}
            </button>
          </form>
        );
      })()
    ) : (
      <button
        type="button"
        data-filter="all"
        class:list={["af-filter-pill", "af-filter-pill-all", active === "all" && "is-active"]}
      >
        {formatLabel(allLabel)}
      </button>
    )
  )}
  {normalizedItems.map((item) => {
    const palette = getTagPalette(item.colorKey ?? item.value, { overrides: colorOverrides });
    const isActive = item.active ?? normalize(active) === normalize(item.value);
    const label = formatLabel(item.label);
    return (
      item.href && !item.disabled ? (
        (() => {
          const form = formPartsFromHref(item.href);
          return (
            <form method="get" action={form.action} data-astro-reload class="af-filter-pill-form">
              {form.fields.map((field) => (
                <input type="hidden" name={field.name} value={field.value} />
              ))}
              <button
                type="submit"
                class:list={["af-filter-pill", isActive && "is-active"]}
                style={{
                  "--af-tag-bg": palette.bg,
                  "--af-tag-border": palette.border,
                  "--af-tag-text": palette.text,
                }}
              >
                {label}
              </button>
            </form>
          );
        })()
      ) : item.disabled ? (
        <button
          type="button"
          disabled
          aria-disabled="true"
          title="Nothing to show with current filters. Reset or remove filters."
          class:list={["af-filter-pill", isActive && "is-active"]}
          style={{
            "--af-tag-bg": palette.bg,
            "--af-tag-border": palette.border,
            "--af-tag-text": palette.text,
          }}
        >
          {label}
        </button>
      ) : (
        <button
          type="button"
          data-filter={item.value}
          class:list={["af-filter-pill", isActive && "is-active"]}
          style={{
            "--af-tag-bg": palette.bg,
            "--af-tag-border": palette.border,
            "--af-tag-text": palette.text,
          }}
        >
          {label}
        </button>
      )
    );
  })}
</div>

<style>
  .af-filter-pill {
    border-radius: 9999px;
    border: 1px solid var(--af-tag-border, var(--color-light-border));
    background: var(--af-tag-bg, color-mix(in oklab, var(--color-light-surface) 80%, transparent));
    color: var(--af-tag-text, color-mix(in oklab, var(--color-light-text-body, #111827) 88%, transparent));
    padding: 0.125rem 0.625rem;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 130ms ease, filter 130ms ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    user-select: none;
    -webkit-user-select: none;
  }
  .af-filter-pill-form {
    display: inline-flex;
    margin: 0;
  }

  .af-filter-pill:hover {
    filter: brightness(0.97) saturate(1.04);
  }
  .af-filter-pill:disabled,
  .af-filter-pill[aria-disabled="true"] {
    cursor: not-allowed;
    opacity: 0.34;
    filter: grayscale(0.45) contrast(0.86);
    color: color-mix(in oklab, var(--af-tag-text, var(--color-light-text-subtle, #6b7280)) 42%, var(--color-light-text-subtle, #6b7280));
  }

  .af-filter-pill.is-active {
    border-color: color-mix(in oklab, var(--af-tag-text, var(--color-secondary)) 80%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--af-tag-text, var(--color-secondary)) 36%, transparent);
    outline: 2px solid color-mix(in oklab, var(--af-tag-text, var(--color-secondary)) 48%, transparent);
    outline-offset: 1px;
    font-weight: 600;
    filter: saturate(1.14) brightness(1.06);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.15em;
  }
  .af-filter-pill.af-filter-pill-all {
    --af-tag-bg: transparent;
    --af-tag-border: color-mix(in oklab, var(--color-light-text-subtle) 45%, transparent);
    --af-tag-text: color-mix(in oklab, var(--color-light-text-body) 92%, transparent);
  }
  .af-filter-pill.af-filter-pill-all.is-active {
    --af-tag-bg: color-mix(in oklab, var(--color-light-text-body) 7%, transparent);
    --af-tag-border: color-mix(in oklab, var(--color-light-text-body) 72%, transparent);
    --af-tag-text: var(--color-light-text-body);
  }
  :global([data-theme="dark"]) .af-filter-pill {
    color: color-mix(in oklab, var(--af-tag-text, #d1d5db) 34%, var(--color-dark-text-body, #f3f4f6));
    border-color: color-mix(in oklab, var(--af-tag-border, var(--color-dark-border)) 62%, var(--color-dark-border) 38%);
    background: color-mix(in oklab, var(--af-tag-bg, transparent) 48%, var(--color-dark-surface, #1f2937) 52%);
  }
  :global([data-theme="dark"]) .af-filter-pill.af-filter-pill-all {
    --af-tag-bg: transparent;
    --af-tag-border: color-mix(in oklab, var(--color-dark-text-subtle) 48%, transparent);
    --af-tag-text: color-mix(in oklab, var(--color-dark-text-body) 90%, transparent);
  }
  :global([data-theme="dark"]) .af-filter-pill.af-filter-pill-all.is-active {
    --af-tag-bg: color-mix(in oklab, var(--color-dark-text-body) 10%, transparent);
    --af-tag-border: color-mix(in oklab, var(--color-dark-text-body) 70%, transparent);
    --af-tag-text: var(--color-dark-text-body);
  }
  :global([data-theme="dark"]) .af-filter-pill:disabled,
  :global([data-theme="dark"]) .af-filter-pill[aria-disabled="true"] {
    opacity: 0.42;
    filter: grayscale(0.35) contrast(0.9);
    color: color-mix(in oklab, var(--color-dark-text-subtle, #9ca3af) 68%, var(--af-tag-text, #d1d5db));
  }
</style>
