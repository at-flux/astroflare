---
import FilterPills from "./FilterPills.astro";
import FilterPanel from "./FilterPanel.astro";
import FilterRow from "./FilterRow.astro";
import Pager from "./Pager.astro";
import {
  buildCollectionHref,
  buildPageSequence,
  normalizeFilterToken,
  parseFilterValueList,
} from "../collection-query";
import type { CollectionQueryProps, CollectionQueryServerProps } from "./collection-query-props";
type Props = CollectionQueryProps;

const {
  useServer = false,
  filters = [],
  filtersTitle = "Filters",
  filtersLabel = "Tags",
  extraFiltersLabel = "Date",
  showExtraFilters = false,
  maxPageButtons = 7,
  filtersClass = "mb-8",
  pagerClass = "mt-6",
  sizeOptions = [4, 2, 8, 12, 16],
  stickyParams = {},
  showPageSize = true,
  pageSizeClass = "",
  perPage = 9,
  class: className = "",
} = Astro.props;

const serverProps = useServer
  ? (Astro.props as CollectionQueryServerProps)
  : null;
const pathname = serverProps?.pathname ?? "";
const query = serverProps?.query ?? { page: 1, size: 9, offset: 0, filters: {} };
const totalPages = serverProps?.totalPages ?? 1;
const currentPage = serverProps?.currentPage ?? 1;
const totalItems = serverProps?.totalItems ?? 0;

const activeFilters = query.filters ?? {};
const normalize = (value: string): string => value.trim().toLowerCase();
const maxTagFilters = 5;
const activeTagTokens = parseFilterValueList(activeFilters.tag);
const lockFiltersToAll = totalItems === 0 && activeTagTokens.length >= 2;
const clearTagFilters = Object.fromEntries(
  Object.entries(activeFilters).filter(([key]) => key !== "tag"),
);
const allHref = buildCollectionHref(pathname, query, { filters: clearTagFilters, page: 1, offset: 0 });
const serverFilterItems = filters.map((option) => {
  const isTagFilter = option.key === "tag";
  const normalizedOptionValue = normalizeFilterToken(option.value);
  const selectedTagTokens = activeTagTokens;
  const isSelectedTag = isTagFilter && selectedTagTokens.includes(normalizedOptionValue);
  const canAddTag = isTagFilter ? selectedTagTokens.length < maxTagFilters : true;
  const nextTagTokens = isTagFilter
    ? (isSelectedTag
        ? selectedTagTokens.filter((token) => token !== normalizedOptionValue)
        : [...selectedTagTokens, normalizedOptionValue]
      )
    : [];
  const nextFilters = { ...activeFilters };
  if (isTagFilter) {
    if (nextTagTokens.length === 0) {
      delete nextFilters.tag;
    } else {
      nextFilters.tag = nextTagTokens.join(",");
    }
  } else {
    nextFilters[option.key] = normalizeFilterToken(option.value);
  }
  const isDisabledTag = isTagFilter && (lockFiltersToAll || (!isSelectedTag && !canAddTag));
  return {
    value: `${option.key}:${option.value}`,
    label: option.label ?? option.value,
    href: isDisabledTag
      ? undefined
      : buildCollectionHref(pathname, query, { filters: nextFilters, page: 1, offset: 0 }),
    active: isTagFilter
      ? isSelectedTag
      : normalize(activeFilters[option.key] ?? "") === normalize(option.value),
    disabled: isDisabledTag,
    colorKey: option.value,
  };
});
const clientFilterItems = filters.map((option) => ({
  value: option.value,
  label: option.label ?? option.value,
  colorKey: option.value,
}));
const pagerItems = buildPageSequence(totalPages, currentPage, maxPageButtons).map((item) =>
  item === "…"
    ? { ellipsis: true as const }
    : {
        page: item,
        href: buildCollectionHref(pathname, query, { page: item, offset: (item - 1) * query.size }),
        active: item === currentPage,
        disabled: totalPages <= 1 || item === currentPage,
      },
);
const sanitizedSizeOptions = Array.from(
  new Set([query.size, ...sizeOptions].filter((value) => Number.isFinite(value) && value > 0)),
).sort((a, b) => a - b);
const pageSizeDisabled = totalItems === 0;
const pageSizeDisabledTitle = "Unavailable ⛔ Nothing to show. Reset filters to change page size.";
const withStickyParams = (href: string): string => {
  if (Object.keys(stickyParams).length === 0) return href;
  const url = new URL(href, "https://astroflare.local");
  for (const [key, value] of Object.entries(stickyParams)) {
    url.searchParams.set(key, value);
  }
  return `${url.pathname}?${url.searchParams.toString()}`;
};
const allHrefWithSticky = withStickyParams(allHref);
const serverFilterItemsWithSticky = serverFilterItems.map((item) => ({
  ...item,
  href: item.href ? withStickyParams(item.href) : item.href,
}));
const pagerItemsWithSticky = pagerItems.map((item) =>
  "href" in item && typeof item.href === "string"
    ? { ...item, href: withStickyParams(item.href) }
    : item,
);
---

{useServer && (
  <>
    <slot
      name="filters"
    >
      {serverFilterItems.length > 0 && (
        <FilterPanel title={filtersTitle}>
          <FilterRow label={filtersLabel}>
            <FilterPills
              items={serverFilterItemsWithSticky}
              allHref={allHrefWithSticky}
              active={activeTagTokens.length === 0 ? "all" : "__filtered__"}
              class={filtersClass}
            />
          </FilterRow>
          {showExtraFilters && Astro.slots.has("extra-filters") && (
            <FilterRow label={extraFiltersLabel}>
              <slot name="extra-filters" />
            </FilterRow>
          )}
        </FilterPanel>
      )}
    </slot>
    <slot />
    <slot name="pager">
      <div class:list={["af-query-pager-row flex items-center justify-between gap-3", pagerClass]}>
        <Pager items={pagerItemsWithSticky} />
        {showPageSize && (
          <form method="get" action={pathname} data-astro-reload class:list={["af-query-size-form md:col-start-3 md:justify-self-end", pageSizeClass]}>
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="offset" value="0" />
            {Object.entries(stickyParams).map(([key, value]) => (
              <input type="hidden" name={key} value={value} />
            ))}
            {Object.keys(activeFilters).length > 0 && (
              <input type="hidden" name="filters" value={JSON.stringify(activeFilters)} />
            )}
            <label
              class:list={["af-page-size-label inline-flex items-center gap-2 text-xs uppercase tracking-[0.08em] text-light-text-subtle dark:text-dark-text-subtle", pageSizeDisabled && "is-disabled"]}
              title={pageSizeDisabled ? pageSizeDisabledTitle : undefined}
            >
              <span>Page size</span>
              <select
                name="size"
                class="select-none rounded-full border border-light-border bg-light-surface px-3 py-1.5 text-xs text-light-text-body dark:border-dark-border dark:bg-dark-surface dark:text-dark-text-body"
                disabled={pageSizeDisabled}
                onchange="this.form?.submit()"
              >
                {sanitizedSizeOptions.map((size) => (
                  <option value={String(size)} selected={size === query.size}>
                    {size}
                  </option>
                ))}
              </select>
            </label>
          </form>
        )}
      </div>
    </slot>
  </>
)}

{!useServer && (
  <collection-query
    class={className}
    data-af-query
    data-per-page={String(perPage)}
    data-max-page-buttons={String(maxPageButtons)}
  >
    <slot
      name="filters"
    >
      {clientFilterItems.length > 0 && (
        <FilterPills
          items={clientFilterItems}
          active="all"
          class={filtersClass}
        />
      )}
    </slot>
    <slot />
    <slot name="pager">
      <Pager class={pagerClass} />
    </slot>
  </collection-query>
)}

{
  !useServer && (
    <script>
      import { initCollectionQueryRoots } from "../runtime/collection-query";
      initCollectionQueryRoots();
    </script>
  )
}

<style is:global>
  .af-page-size-label {
    user-select: none;
    -webkit-user-select: none;
  }
  .af-page-size-label select,
  .af-page-size-label option {
    user-select: none;
    -webkit-user-select: none;
  }
  .af-page-size-label.is-disabled {
    opacity: 0.58;
    cursor: not-allowed;
  }
  .af-page-size-label.is-disabled select {
    cursor: not-allowed;
    border-style: dashed;
  }
</style>
