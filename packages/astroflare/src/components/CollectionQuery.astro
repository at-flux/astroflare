---
import FilterPills from "./FilterPills.astro";
import Pager from "./Pager.astro";
import { buildCollectionHref, buildPageSequence } from "../collection-query";
import type { CollectionQueryProps, CollectionQueryServerProps } from "./collection-query-props";
type Props = CollectionQueryProps;

const {
  useServer = false,
  filters = [],
  maxPageButtons = 7,
  filtersClass = "mb-8",
  pagerClass = "mt-6",
  sizeOptions = [4, 2, 8, 12, 16],
  showPageSize = true,
  pageSizeClass = "",
  perPage = 9,
  class: className = "",
} = Astro.props;

const serverProps = useServer
  ? (Astro.props as CollectionQueryServerProps)
  : null;
const pathname = serverProps?.pathname ?? "";
const query = serverProps?.query ?? { page: 1, size: 9, offset: 0, filters: {} };
const totalPages = serverProps?.totalPages ?? 1;
const currentPage = serverProps?.currentPage ?? 1;

const activeFilters = query.filters ?? {};
const allHref = buildCollectionHref(pathname, query, { filters: {}, page: 1, offset: 0 });
const serverFilterItems = filters.map((option) => {
  const nextFilters = { ...activeFilters, [option.key]: option.value };
  return {
    value: `${option.key}:${option.value}`,
    label: option.label ?? option.value,
    href: buildCollectionHref(pathname, query, { filters: nextFilters, page: 1, offset: 0 }),
    active: activeFilters[option.key] === option.value,
    colorKey: option.value,
  };
});
const clientFilterItems = filters.map((option) => ({
  value: option.value,
  label: option.label ?? option.value,
  colorKey: option.value,
}));
const pagerItems = buildPageSequence(totalPages, currentPage, maxPageButtons).map((item) =>
  item === "…"
    ? { ellipsis: true as const }
    : {
        page: item,
        href: buildCollectionHref(pathname, query, { page: item, offset: (item - 1) * query.size }),
        active: item === currentPage,
        disabled: totalPages <= 1 || item === currentPage,
      },
);
const sanitizedSizeOptions = Array.from(
  new Set([query.size, ...sizeOptions].filter((value) => Number.isFinite(value) && value > 0)),
).sort((a, b) => a - b);
---

{useServer && (
  <>
    <slot
      name="filters"
    >
      {serverFilterItems.length > 0 && (
        <FilterPills
          items={serverFilterItems}
          allHref={allHref}
          active={Object.keys(activeFilters).length === 0 ? "all" : "__filtered__"}
          class={filtersClass}
        />
      )}
    </slot>
    <slot />
    <slot name="pager">
      <div class:list={["af-query-pager-row flex flex-col gap-3 md:flex-row md:items-center md:justify-between", pagerClass]}>
        <Pager items={pagerItems} class="md:order-1 md:flex-1 md:justify-center" />
        {showPageSize && (
          <form method="get" action={pathname} class:list={["af-query-size-form md:order-2 md:ml-auto", pageSizeClass]}>
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="offset" value="0" />
            {Object.keys(activeFilters).length > 0 && (
              <input type="hidden" name="filters" value={JSON.stringify(activeFilters)} />
            )}
            <label class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.08em] text-light-text-subtle dark:text-dark-text-subtle">
              <span>Page size</span>
              <select
                name="size"
                class="rounded-full border border-light-border bg-light-surface px-3 py-1.5 text-xs text-light-text-body dark:border-dark-border dark:bg-dark-surface dark:text-dark-text-body"
                onchange="this.form?.submit()"
              >
                {sanitizedSizeOptions.map((size) => (
                  <option value={String(size)} selected={size === query.size}>
                    {size}
                  </option>
                ))}
              </select>
            </label>
          </form>
        )}
      </div>
    </slot>
  </>
)}

{!useServer && (
  <collection-query
    class={className}
    data-af-query
    data-per-page={String(perPage)}
    data-max-page-buttons={String(maxPageButtons)}
  >
    <slot
      name="filters"
    >
      {clientFilterItems.length > 0 && (
        <FilterPills
          items={clientFilterItems}
          active="all"
          class={filtersClass}
        />
      )}
    </slot>
    <slot />
    <slot name="pager">
      <Pager class={pagerClass} />
    </slot>
  </collection-query>
)}

{
  !useServer && (
    <script>
      import { initCollectionQueryRoots } from "../runtime/collection-query";
      initCollectionQueryRoots();
    </script>
  )
}
