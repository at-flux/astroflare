---
interface Props {
  /** Instagram username without @ */
  handle: string;
  /** Optional explicit profile URL (defaults to `https://www.instagram.com/{handle}`). */
  href?: string;
  /** Classes merged onto the anchor element. */
  class?: string;
  /** Optional accessible label override for the link. */
  'aria-label'?: string;
}

const {
  handle: rawHandle,
  href,
  class: className = '',
  'aria-label': ariaLabel,
} = Astro.props;

const handle = rawHandle.replace(/^@/, '');
const url = href ?? `https://www.instagram.com/${handle}`;
const a11yLabel = ariaLabel ?? `Instagram: @${handle}`;
---

<a
  href={url}
  target='_blank'
  rel='noopener noreferrer'
  class:list={['area-handle no-underline', className]}
  aria-label={a11yLabel}
>
  <svg
    width='13'
    height='13'
    viewBox='0 0 24 24'
    fill='none'
    stroke='currentColor'
    stroke-width='2'
    stroke-linecap='round'
    stroke-linejoin='round'
    aria-hidden='true'
  >
    <rect x='2' y='2' width='20' height='20' rx='5' ry='5' />
    <circle cx='12' cy='12' r='5' />
    <circle cx='17.5' cy='6.5' r='1.5' fill='currentColor' stroke='none' />
  </svg>
  @{handle}
</a>
