{
  "name": "@at-flux/dom",
  "version": "1.0.1",
  "type": "module",
  "description": "Type-safe DOM helpers for Astroflare projects",
  "author": "atflux <dev@atflux.uk>",
  "license": "MIT",
  "keywords": [
    "astro",
    "dom",
    "utilities",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/astroflare.git",
    "directory": "packages/dom"
  },
  "bugs": {
    "url": "https://github.com/at-flux/astroflare/issues"
  },
  "homepage": "https://github.com/at-flux/astroflare/tree/main/packages/dom",
  "publishConfig": {
    "access": "public"
  }
}
