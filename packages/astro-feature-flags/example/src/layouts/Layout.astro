---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Feature flags example' } = Astro.props;
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{title}</title>
  </head>
  <body class='min-h-screen bg-slate-100 text-slate-900 antialiased'>
    <slot />
  </body>
</html>
