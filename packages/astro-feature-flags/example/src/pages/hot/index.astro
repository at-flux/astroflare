---
import Layout from '../../layouts/Layout.astro';
import { FeatureFlag, FeatureToken, shouldRenderFeature } from 'virtual:astro-feature-flags';
---

<Layout title='Hot'>
  <main style='padding: 1.5rem; max-width: 40rem'>
    <h1 style='margin-top: 0'>Hot route</h1>
    <p>Top-right badge uses the <strong>hotFeature2</strong> colour when this route matches <code>ff.json</code>.</p>

    <div data-ff={FeatureToken.HotFeature2} class='ff-demo-box'>
      Outline and badge for <code>hotFeature2</code> via <code>data-ff</code>.
    </div>

    {
      shouldRenderFeature(FeatureFlag.Dev) && (
        <div data-ff={FeatureToken.Dev} class='ff-demo-box'>
          Dev block for comparison.
        </div>
      )
    }

    <p style='margin-top: 1.5rem'>
      <a href={`${import.meta.env.BASE_URL}`}>← Home</a>
    </p>
  </main>
</Layout>

<style>
  .ff-demo-box {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 0.5rem;
    background: color-mix(in oklab, Canvas 96%, CanvasText 4%);
  }
</style>
