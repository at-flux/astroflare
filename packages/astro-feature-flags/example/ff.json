    "dev": {
      "flags": {
        "dev": true,
        "hotFeature1": true,
        "hotFeature2": true
      }
    },
    "prod": {
      "flags": {
        "dev": false,
        "hotFeature1": true,
        "hotFeature2": false
      }
    }
  }
