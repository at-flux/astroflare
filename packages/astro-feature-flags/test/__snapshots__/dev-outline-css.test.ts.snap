html {
  --aff-outline-c-wip: transparent;
}
html:not([data-ff-outline-wip="off"]) {
  --aff-outline-c-wip: var(--snap-c-wip, #ff0000);
}
[data-snap~="wip"]:not([data-snap*=" "]), [data-snap-wip]:not([data-snap*=" "]) {
  position: relative;
  outline: 2px solid var(--aff-outline-c-wip);
  outline-offset: -2px;
  border-radius: 0.5rem;
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])::before {
  box-sizing: border-box;
  position: absolute;
  inset: auto;
  margin: 0;
  width: max-content;
  max-width: min(18rem, calc(100% - 0.75rem));
  pointer-events: auto;
  z-index: 20;
  left: auto;
  right: 0.35rem;
  top: 0;
  bottom: auto;
  transform: translateY(calc(-1 * 80%));
  display: block;
  content: 'wip';
  border: 1px solid color-mix(in oklab, var(--snap-c-wip, #ff0000) 60%, transparent);
  border-radius: 9999px;
  padding: 0.125rem 0.45rem;
  font-size: 0.625rem;
  line-height: 1.2;
  letter-spacing: 0.02em;
  font-weight: 600;
  color: var(--snap-c-wip, #ff0000);
  background: color-mix(in oklab, white 85%, var(--snap-c-wip, #ff0000) 15%);
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  transition: opacity 0.14s ease, background 0.14s ease, border-color 0.14s ease;
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "]):hover::before {
  opacity: 0.16;
  background: color-mix(in oklab, white 94%, var(--snap-c-wip, #ff0000) 6%);
  border-color: color-mix(in oklab, var(--snap-c-wip, #ff0000) 35%, transparent);
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-align="start"]::before {
  left: 0.35rem;
  right: auto;
  transform: translateY(calc(-1 * 80%));
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-align="center"]::before {
  left: 50%;
  right: auto;
  transform: translate(-50%, calc(-1 * 80%));
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-align="end"]::before {
  left: auto;
  right: 0.35rem;
  transform: translateY(calc(-1 * 80%));
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-horizontal]::before {
  left: calc(attr(data-ff-horizontal number, 50) * 1%);
  right: auto;
  transform: translate(-50%, calc(-1 * 80%));
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-horizontal][data-ff-anchor="bottom"]::before {
  transform: translate(-50%, 80%);
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-anchor="bottom"]::before {
  top: auto;
  bottom: 0;
  transform: translateY(80%);
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-anchor="bottom"][data-ff-align="center"]::before {
  transform: translate(-50%, 80%);
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-vertical]::before {
  transform: translateY(calc(attr(data-ff-vertical number, 80) * -1%));
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-horizontal][data-ff-vertical]::before {
  transform: translate(-50%, calc(attr(data-ff-vertical number, 80) * -1%));
}
html:not([data-ff-badge-wip="off"]) :is([data-snap~="wip"], [data-snap-wip]):not([data-snap*=" "])[data-ff-anchor="bottom"][data-ff-vertical]::before {
