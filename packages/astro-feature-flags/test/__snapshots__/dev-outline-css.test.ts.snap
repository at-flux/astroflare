[data-snap*=" "] {
  position: relative;
  outline: none !important;
  outline-offset: 0 !important;
  border-radius: 0.5rem;
}
html [data-snap*=" "]::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 10;
  box-sizing: border-box;
  padding: 2px;
  background: var(--ff-combo-gradient, linear-gradient(90deg, #fecaca, #bfdbfe, #bbf7d0));
  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}
html [data-snap*=" "]::before {
  box-sizing: border-box;
  position: absolute;
  inset: auto;
  margin: 0;
  width: max-content;
  max-width: min(18rem, calc(100% - 0.75rem));
  pointer-events: auto;
  z-index: 20;
  left: auto;
  right: 0.35rem;
  top: 0;
  bottom: auto;
  transform: translateY(calc(-1 * 80%));
  display: block;
  content: attr(data-snap);
  background: var(--ff-combo-badge-gradient, var(--ff-combo-gradient-soft, linear-gradient(90deg, #fff1f2, #eff6ff, #f0fdf4))) !important;
  color: var(--ff-combo-text, #111827) !important;
  border: 1px solid var(--ff-combo-badge-border, color-mix(in oklab, #94a3b8 50%, transparent)) !important;
  border-radius: 9999px;
  padding: 0.125rem 0.45rem;
  font-size: 0.625rem;
  line-height: 1.2;
  letter-spacing: 0.02em;
  font-weight: 600;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
  transition: opacity 0.14s ease, background 0.14s ease, border-color 0.14s ease;
}
html [data-snap*=" "][data-ff-label]::before {
  content: attr(data-ff-label) !important;
}
html [data-snap*=" "]:hover::before {
  opacity: 0.2;
  background: linear-gradient(90deg, #fff8f9, #f8fbff, #f8fff9);
  border-color: color-mix(in oklab, #94a3b8 35%, transparent);
}


html[data-ff-badge-wip="off"] :is([data-snap~="wip"], [data-snap-wip])[data-snap*=" "]::before,
html[data-ff-badge-wip="off"] :is([data-snap~="wip"], [data-snap-wip])[data-snap*=" "][data-ff-label]::before {
  display: none !important;
  content: none !important;
}
html[data-ff-badge-wip="off"] :is([data-snap~="wip"], [data-snap-wip])[data-snap*=" "]:hover::before,
html[data-ff-badge-wip="off"] :is([data-snap~="wip"], [data-snap-wip])[data-snap*=" "][data-ff-label]:hover::before {
  display: none !important;
  opacity: 1 !important;
  background: none !important;
  border-color: transparent !important;
}
html[data-ff-outline-wip="off"] :is([data-snap~="wip"], [data-snap-wip])[data-snap*=" "] {
  outline: none !important;
  outline-offset: 0 !important;
}
html[data-ff-outline-wip="off"] :is([data-snap~="wip"], [data-snap-wip])[data-snap*=" "]::after {
