html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-horizontal][data-ff-anchor="bottom"]::before {
  transform: translate(-50%, 80%);
}
html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-anchor="bottom"]::before {
  top: auto;
  bottom: 0;
  transform: translateY(80%);
}
html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-anchor="bottom"][data-ff-align="center"]::before {
  transform: translate(-50%, 80%);
}
html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-vertical]::before {
  transform: translateY(calc(attr(data-ff-vertical number, 80) * -1%));
}
html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-horizontal][data-ff-vertical]::before {
  transform: translate(-50%, calc(attr(data-ff-vertical number, 80) * -1%));
}
html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-anchor="bottom"][data-ff-vertical]::before {
  transform: translateY(calc(attr(data-ff-vertical number, 80) * 1%));
}
html:not([data-ff-badge-beta="off"]) :is([data-snap~="beta"], [data-snap-beta])[data-ff-anchor="bottom"][data-ff-horizontal][data-ff-vertical]::before {
  transform: translate(-50%, calc(attr(data-ff-vertical number, 80) * 1%));
}
html[data-ff-enabled-beta="off"] :is([data-snap~="beta"], [data-snap-beta]) {
  display: none !important;
}


[data-snap*=" "] {
  outline: none !important;
  outline-offset: 0 !important;
  border: 2px solid transparent;
  background:
    linear-gradient(white, white) padding-box,
    var(--ff-combo-gradient, linear-gradient(90deg, #fecaca, #bfdbfe, #bbf7d0)) border-box;
  border-radius: 0.5rem;
}
html [data-snap*=" "]::before {
  content: attr(data-snap);
  background: var(--ff-combo-badge-gradient, var(--ff-combo-gradient-soft, linear-gradient(90deg, #fff1f2, #eff6ff, #f0fdf4))) !important;
  color: var(--ff-combo-text, #111827) !important;
  border: 1px solid var(--ff-combo-badge-border, color-mix(in oklab, #94a3b8 50%, transparent)) !important;
  transition: opacity 0.14s ease, background 0.14s ease, border-color 0.14s ease;
}
html [data-snap*=" "][data-ff-label]::before {
  content: attr(data-ff-label) !important;
}
html [data-snap*=" "]:hover::before {
  opacity: 0.2;
  background: linear-gradient(90deg, #fff8f9, #f8fbff, #f8fff9);
  border-color: color-mix(in oklab, #94a3b8 35%, transparent);
}
html[data-ff-route]:not([data-ff-route=""]) body::after {
  content: '';
  position: fixed;
  inset: 0.6rem;
  pointer-events: none;
  z-index: 10040;
  padding: 2px;
  background: var(--ff-route-outline-gradient, linear-gradient(90deg, #ef4444, #3b82f6, #22c55e));
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  border-radius: 0.5rem;
}
html[data-ff-route]:not([data-ff-route=""])::before {
  content: attr(data-ff-route-label);
  position: fixed;
  top: 0.75rem;
  right: 0.75rem;
  z-index: 10060;
  pointer-events: auto;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  max-width: min(34rem, calc(100vw - 1.5rem));
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border: 1px solid var(--ff-route-badge-border, color-mix(in oklab, #94a3b8 55%, transparent));
  border-radius: 9999px;
  padding: 0.15rem 0.5rem;
  font-size: 0.625rem;
  line-height: 1.2;
  letter-spacing: 0.02em;
  font-weight: 600;
  color: var(--ff-route-text, #111827);
  background: var(--ff-route-badge-gradient, linear-gradient(90deg, #fff1f2));
  opacity: 1;
  transition: opacity 0.14s ease, border-color 0.14s ease, background 0.14s ease;
}
html[data-ff-route]:not([data-ff-route=""])::before:hover {
  opacity: 0.2;
  border-color: color-mix(in oklab, #94a3b8 35%, transparent);
}

"
`;
