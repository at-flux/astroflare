{
  "name": "@atflux/astroflare-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10"
  },
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/at-flux/astroflare.git"
  },
  "homepage": "https://github.com/at-flux/astroflare#readme",
  "bugs": {
    "url": "https://github.com/at-flux/astroflare/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "release": "multi-semantic-release",
    "publish:astroflare": "pnpm --filter @at-flux/astroflare publish",
    "publish:dom": "pnpm --filter @at-flux/dom publish",
    "publish:packages": "pnpm publish -r --access public --filter './packages/*'",
    "format": "prettier --write '**/*.{ts,js,json,md,astro,css}' --ignore-unknown",
    "format:check": "prettier --check '**/*.{ts,js,json,md,astro,css}' --ignore-unknown",
    "publish:astro-feature-flags": "pnpm --filter @at-flux/astro-feature-flags publish"
  },
  "devDependencies": {
    "@qiwi/multi-semantic-release": "^7.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
